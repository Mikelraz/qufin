# Template for broker credentials. Copy to .env and fill in.
# .env is gitignored; .env.example is safe to commit.

# Alpaca paper or live (paper endpoint is the default in AlpacaBroker).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Interactive Brokers TWS / Gateway connection
IBKR_HOST=127.0.0.1
IBKR_PORT=7497  # 7497 = paper TWS, 7496 = live TWS, 4002 = paper Gateway, 4001 = live Gateway
IBKR_CLIENT_ID=1
